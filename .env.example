# =============================================================================
# AIryss vNext - 環境変数テンプレート
# このファイルを .env にコピーして各値を設定してください
# =============================================================================

# --- アプリケーション ---
APP_ENV=development
APP_SECRET_KEY=change-me-in-production

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=airyss
POSTGRES_USER=airyss
POSTGRES_PASSWORD=change-me

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Web ---
NEXT_PUBLIC_API_URL=http://localhost/api

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=

# --- AI (OpenAI) - 将来用 ---
OPENAI_API_KEY=
